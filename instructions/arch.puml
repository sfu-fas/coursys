' To generate diagram:
' sudo apt install plantuml
' plantuml arch.puml 

' https://github.com/plantuml/plantuml-stdlib/tree/master/stdlib/logos

@startuml

!include <logos/nginx>
!include <logos/gunicorn>
!include <logos/django>
!include <logos/rabbitmq>
!include <logos/ruby>
!include <logos/python>
!include <logos/rabbitmq>
!include <logos/memcached>
!include <logos/elasticsearch>
!include <logos/mariadb>

actor Users as users

agent "SFUCloud Load Balancer\n(terminates HTTPS)" as lb

users <-> lb : HTTPS

package "Docker" {    
    folder "static" as static
    control "Daily Import\nTask" as import
    
    agent "<$python>\nCelery" as celery
    agent "Celerybeat" as celerybeat
    agent "<$nginx>\nNginx" as nginx
    agent "<$python>\nGunicorn" as gunicorn

    queue "<$rabbitmq>\nRabbitMQ" as rabbitmq
    database "<$memcached>\nMemcached" as memcached
    database "<$elasticsearch>\nElasticsearch" as elasticsearch
    agent "Logrotate" as logrotate

    static <-- gunicorn  : "compressor"
    'gunicorn --> static : "compressor"
    nginx <-- static : static files
    nginx <---> gunicorn : dynamic pages
    
    gunicorn ..> rabbitmq : tasks
    celery <.. rabbitmq : tasks
    gunicorn <--> memcached : cache
    gunicorn <--> elasticsearch : search
    rabbitmq <.. celerybeat : periodic\ntasks

    control "manage\ncollectstatic" as collectstatic

}

package "Onara" {
    database "<$mariadb>\nDatabase" as db
}

lb <--> nginx : HTTP
gunicorn <-> db
celery <--> db
db <- import

'package "External APIs" {
    database "CSRPT" as csrpt
    agent "CAS" as cas
    database "Photo API" as photo
    database "AMAINT" as amaint
    cloud "outgoing\nemail" as email
'}

csrpt --> import
'celery <-- csrpt
csrpt --> celery
gunicorn <.> cas : auth
celery <-- photo
email <-- celery
amaint -> import

'static <- collectstatic : "writes"
collectstatic -> static : "writes"

folder "nginx_logs" as nginx_logs
nginx_logs <.. nginx : writes
nginx_logs <.. logrotate : rotates

@enduml
